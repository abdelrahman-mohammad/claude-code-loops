{
  "name": "claude-code-loops",
  "version": "0.2.0",
  "description": "Autonomous code-review-fix loops for Claude Code",
  "type": "module",
  "bin": {
    "claude-code-loops": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agentic",
    "code-review",
    "automation",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdelrahman-mohammad/claude-code-loops.git"
  },
  "bugs": {
    "url": "https://github.com/abdelrahman-mohammad/claude-code-loops/issues"
  },
  "homepage": "https://github.com/abdelrahman-mohammad/claude-code-loops#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
